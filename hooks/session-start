#!/usr/bin/env bash

# Composto session-start hook
# Injects the composto-bootstrap skill into the AI agent's context

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_DIR="$(dirname "$SCRIPT_DIR")"
SKILL_FILE="$PLUGIN_DIR/skills/composto-bootstrap/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
  exit 0
fi

# Read skill content, escape for JSON
SKILL_CONTENT=$(cat "$SKILL_FILE" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" 2>/dev/null)

if [ -z "$SKILL_CONTENT" ]; then
  SKILL_CONTENT=$(cat "$SKILL_FILE" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | tr '\n' '\\' | sed 's/\\/\\n/g')
  SKILL_CONTENT="\"$SKILL_CONTENT\""
fi

cat <<EOF
{
  "hookSpecificOutput": {
    "additionalContext": $SKILL_CONTENT
  }
}
EOF
